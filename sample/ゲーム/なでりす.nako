#-----------------------------------------------------------------------
# 棊偪偰偔傞僽儘僢僋偺宍忬傪掕媊
#-----------------------------------------------------------------------
棊偪儌僲[0] = 乽3,3乿  &夵峴&
              乽3,3乿
棊偪儌僲[1] = 乽2,2,2乿&夵峴&
丂丂丂丂丂丂丂乽2,0,0乿
棊偪儌僲[2] = 乽3,3,3乿&夵峴&
丂丂丂丂丂丂丂乽0,0,3乿
棊偪儌僲[3] = 乽0,4,4乿&夵峴&
丂丂丂丂丂丂丂乽4,4,0乿
